PORT=3001
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=NewPassword@123
DB_NAME=studio_hr

# AI provider: kimi | deepseek | qwen | glm | custom
AI_PROVIDER=kimi

# If AI_PROVIDER is set, AI_BASE_URL can be omitted for built-in presets.
# For custom OpenAI-compatible providers, set AI_BASE_URL explicitly.
# AI_BASE_URL=https://api.moonshot.cn/v1

AI_API_KEY=your_api_key_here

# Optional model overrides
AI_MODEL_QUESTION=kimi-k2.5
AI_MODEL_EVAL=kimi-k2.5

# Optional
AI_TIMEOUT_MS=60000
AI_FORCE_JSON=true

