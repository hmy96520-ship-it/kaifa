PORT=3001
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=NewPassword@123
DB_NAME=studio_hr

# AI provider: kimi | deepseek | qwen | glm | custom
AI_PROVIDER=custom

# If AI_PROVIDER is set, AI_BASE_URL can be omitted for built-in presets.
# For custom OpenAI-compatible providers, set AI_BASE_URL explicitly.
AI_BASE_URL=http://vivii.dpdns.org:58080

# Either AI_API_KEY or OPENAI_API_KEY can be used.
AI_API_KEY=your_api_key_here

# Optional model overrides
AI_MODEL_QUESTION=gpt-5.4
AI_MODEL_EVAL=gpt-5.4

# chat_completions | responses
AI_WIRE_API=responses

# low | medium | high | xhigh (used when AI_WIRE_API=responses)
AI_REASONING_EFFORT=xhigh

# Only used when AI_WIRE_API=responses
AI_DISABLE_RESPONSE_STORAGE=true

# Optional
AI_TIMEOUT_MS=60000
AI_FORCE_JSON=true

# Optional stable transcription channel (Aliyun realtime ASR over WebSocket)
# Example:
# ASR_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference/
# ASR_API_KEY=your_dashscope_api_key_here
# ASR_MODEL=fun-asr-realtime
ASR_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference/
ASR_API_KEY=
ASR_MODEL=fun-asr-realtime
ASR_FORMAT=pcm
ASR_SAMPLE_RATE=16000
ASR_LANGUAGE_HINTS=zh
ASR_VOCABULARY_ID=
ASR_WORKSPACE=
ASR_DISFLUENCY_REMOVAL_ENABLED=false
ASR_CONNECT_TIMEOUT_MS=10000

